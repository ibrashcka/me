<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Ibrahim Bin Hemeil</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg:#0A0D12; --bg2:#0F1318; --bg3:#141820;
  --line:#1E2530; --gold:#C9A84C; --gold2:#E8C96A;
  --text:#E8E4DC; --muted:#7A8090; --dim:#4A5060;
  --white:#F5F2EC;
  --serif:"Cormorant Garamond",Georgia,serif;
  --sans:"DM Sans",sans-serif;
  --mono:"DM Mono",monospace;
  --arabic:"Tajawal",sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-weight:300;line-height:1.7;overflow-x:hidden}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:2px}

body.ar{font-family:var(--arabic);direction:rtl}
body.ar .nav-logo{font-family:var(--arabic)}
body.ar .hero-label::before,body.ar .section-label::before{display:none}
body.ar .hero-label::after,body.ar .section-label::after{content:"";display:inline-block;width:24px;height:1px;background:var(--gold)}
body.ar .exp-item::before{left:auto;right:0}
body.ar nav{direction:rtl}
body.ar .nav-links{flex-direction:row-reverse}
body.ar footer{flex-direction:row-reverse}

.lang-btn{background:transparent;border:1px solid var(--line);color:var(--muted);font-family:var(--mono);font-size:0.72rem;letter-spacing:0.1em;padding:0.35rem 0.85rem;cursor:pointer;transition:all 0.3s}
.lang-btn:hover{border-color:var(--gold);color:var(--gold)}

nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1.2rem 4rem;background:rgba(10,13,18,0.88);backdrop-filter:blur(16px);border-bottom:1px solid var(--line)}
.nav-logo{font-family:var(--serif);font-size:1.1rem;font-weight:500;color:var(--gold);letter-spacing:0.04em;text-decoration:none}
.nav-right{display:flex;align-items:center;gap:2rem}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:0.73rem;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color 0.3s}
.nav-links a:hover,.nav-links a.active{color:var(--gold)}

#hero{min-height:100vh;display:flex;align-items:center;padding:0 4rem;position:relative;overflow:hidden}
.geo-bg{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.geo-ring{position:absolute;border:1px solid rgba(201,168,76,0.07);border-radius:50%;animation:rot linear infinite}
.geo-ring:nth-child(1){width:600px;height:600px;right:-150px;top:-100px;animation-duration:60s}
.geo-ring:nth-child(2){width:950px;height:950px;right:-320px;top:-280px;animation-duration:90s;animation-direction:reverse;border-color:rgba(201,168,76,0.03)}
.geo-ring:nth-child(3){width:380px;height:380px;right:60px;top:60px;animation-duration:45s;border-color:rgba(201,168,76,0.05)}
@keyframes rot{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.geo-dot{position:absolute;width:3px;height:3px;background:var(--gold);border-radius:50%;opacity:0.35}
.geo-dot:nth-child(4){top:18%;left:8%}
.geo-dot:nth-child(5){top:68%;left:4%}
.geo-dot:nth-child(6){top:42%;left:52%}

.hero-inner{display:grid;grid-template-columns:1fr auto;gap:5rem;align-items:center;width:100%;max-width:1200px;position:relative;z-index:2}
.hero-content{animation:fadeUp 0.9s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.hero-label{font-family:var(--mono);font-size:0.7rem;letter-spacing:0.2em;color:var(--gold);text-transform:uppercase;margin-bottom:1.2rem;display:flex;align-items:center;gap:0.8rem}
.hero-label::before{content:"";display:inline-block;width:32px;height:1px;background:var(--gold)}
.hero-name{font-family:var(--serif);font-size:clamp(3rem,5.5vw,5rem);font-weight:300;line-height:1.05;color:var(--white);margin-bottom:1rem;letter-spacing:-0.01em}
.hero-name span{color:var(--gold);font-weight:500}
.hero-title{font-size:0.95rem;color:var(--muted);margin-bottom:2rem;max-width:480px;line-height:1.65}
.hero-stats{display:flex;gap:2.5rem;margin-bottom:2.5rem;padding:1.4rem 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.stat-num{font-family:var(--serif);font-size:2rem;font-weight:500;color:var(--gold);line-height:1}
.stat-label{font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--dim);margin-top:0.3rem}
.hero-cta{display:flex;gap:1rem}

.hero-photo-wrap{position:relative;flex-shrink:0;animation:fadeUp 1s 0.2s ease both}
.hero-photo-frame{width:320px;height:400px;position:relative;overflow:hidden;border:1px solid var(--line)}
.hero-photo-frame img{width:100%;height:100%;object-fit:cover;object-position:top center;filter:grayscale(15%)}
.hero-photo-frame::before{content:"";position:absolute;inset:0;background:linear-gradient(to bottom,transparent 55%,var(--bg) 100%);z-index:1}
.photo-corner{position:absolute;width:36px;height:36px;border-color:var(--gold);border-style:solid;opacity:0.6;z-index:2}
.photo-corner.tl{top:12px;left:12px;border-width:1px 0 0 1px}
.photo-corner.tr{top:12px;right:12px;border-width:1px 1px 0 0}
.photo-corner.bl{bottom:12px;left:12px;border-width:0 0 1px 1px}
.photo-corner.br{bottom:12px;right:12px;border-width:0 1px 1px 0}
.photo-tag{position:absolute;bottom:0;left:0;right:0;text-align:center;padding:1rem;z-index:3;font-family:var(--mono);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold)}

.btn{display:inline-flex;align-items:center;gap:0.5rem;padding:0.72rem 1.7rem;font-family:var(--sans);font-size:0.75rem;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;transition:all 0.3s;cursor:pointer;border:none}
.btn-primary{background:var(--gold);color:var(--bg)}
.btn-primary:hover{background:var(--gold2)}
.btn-outline{background:transparent;color:var(--muted);border:1px solid var(--line)}
.btn-outline:hover{border-color:var(--gold);color:var(--gold)}

section{padding:6rem 4rem}
.section-inner{max-width:1100px;margin:0 auto}
.section-label{font-family:var(--mono);font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.8rem}
.section-label::before{content:"";display:inline-block;width:24px;height:1px;background:var(--gold)}
.section-title{font-family:var(--serif);font-size:clamp(1.9rem,3vw,2.8rem);font-weight:300;color:var(--white);margin-bottom:3rem;line-height:1.2}

/* About */
#about{background:var(--bg2)}
.about-grid{display:grid;grid-template-columns:340px 1fr;gap:4rem;align-items:start}
.about-photo-frame{width:100%;aspect-ratio:3/4;overflow:hidden;border:1px solid var(--line);position:relative}
.about-photo-frame img{width:100%;height:100%;object-fit:cover;object-position:top center}
.about-photo-frame::after{content:"";position:absolute;bottom:0;left:0;right:0;height:30%;background:linear-gradient(to bottom,transparent,var(--bg2))}
.about-photo-frame .photo-corner{opacity:0.4}
.about-tag{background:var(--gold);color:var(--bg);font-size:0.68rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;padding:0.5rem;text-align:center}
.about-text p{font-size:0.9rem;color:var(--muted);margin-bottom:1.1rem;line-height:1.8}
.about-text p strong{color:var(--text);font-weight:400}
.about-details{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem;margin-top:2rem;padding-top:2rem;border-top:1px solid var(--line)}
.detail-key{font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--dim);margin-bottom:0.2rem}
.detail-val{font-size:0.85rem;color:var(--text)}

/* Achievements / Awards */
#achievements{background:var(--bg)}
.awards-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
.award-card{background:var(--bg3);border:1px solid var(--line);padding:2rem;position:relative;overflow:hidden;transition:border-color 0.3s}
.award-card::before{content:"";position:absolute;top:0;left:0;width:3px;height:0;background:var(--gold);transition:height 0.4s ease}
.award-card:hover{border-color:rgba(201,168,76,0.35)}
.award-card:hover::before{height:100%}
.award-badge{display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.25);font-size:1.4rem;margin-bottom:1.1rem}
.award-year{font-family:var(--mono);font-size:0.68rem;color:var(--gold);letter-spacing:0.14em;margin-bottom:0.5rem}
.award-title{font-family:var(--serif);font-size:1.2rem;font-weight:400;color:var(--white);margin-bottom:0.5rem;line-height:1.3}
.award-org{font-size:0.75rem;color:var(--gold);margin-bottom:0.8rem;font-weight:400}
.award-desc{font-size:0.82rem;color:var(--muted);line-height:1.7}

/* Experience */
#experience{background:var(--bg2)}
.exp-item{display:grid;grid-template-columns:190px 1fr;gap:3rem;padding:2.5rem 0;border-bottom:1px solid var(--line);position:relative}
.exp-item:first-child{border-top:1px solid var(--line)}
.exp-item::before{content:"";position:absolute;left:0;top:0;bottom:0;width:2px;background:transparent;transition:background 0.3s}
.exp-item:hover::before{background:var(--gold)}
.exp-period{font-family:var(--mono);font-size:0.7rem;color:var(--gold);letter-spacing:0.08em;margin-bottom:0.4rem}
.exp-org{font-size:0.8rem;color:var(--dim);line-height:1.4}
.exp-role{font-family:var(--serif);font-size:1.35rem;font-weight:400;color:var(--white);margin-bottom:0.7rem}
.exp-desc{font-size:0.85rem;color:var(--muted);line-height:1.75;margin-bottom:1rem}
.tags{display:flex;flex-wrap:wrap;gap:0.45rem}
.tag{font-size:0.65rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--dim);border:1px solid var(--line);padding:0.22rem 0.65rem;transition:all 0.3s}
.exp-item:hover .tag{border-color:rgba(201,168,76,0.25);color:var(--muted)}

/* Skills */
#skills{background:var(--bg)}
.skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
.skill-card{background:var(--bg3);border:1px solid var(--line);padding:1.8rem;position:relative;overflow:hidden;transition:border-color 0.3s}
.skill-card::after{content:"";position:absolute;top:0;left:0;width:2px;height:0;background:var(--gold);transition:height 0.4s ease}
.skill-card:hover{border-color:rgba(201,168,76,0.3)}
.skill-card:hover::after{height:100%}
.skill-icon{font-size:1.4rem;margin-bottom:0.9rem;display:block}
.skill-name{font-family:var(--serif);font-size:1.1rem;font-weight:400;color:var(--white);margin-bottom:0.7rem}
.skill-items{list-style:none;display:flex;flex-direction:column;gap:0.3rem}
.skill-items li{font-size:0.78rem;color:var(--dim);display:flex;align-items:center;gap:0.45rem}
.skill-items li::before{content:"";display:inline-block;width:4px;height:4px;background:var(--gold);border-radius:50%;flex-shrink:0;opacity:0.6}

/* Projects */
#projects{background:var(--bg2)}
.projects-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
.proj-card{background:var(--bg3);border:1px solid var(--line);padding:2.2rem;transition:all 0.3s;position:relative;overflow:hidden}
.proj-card::before{content:"";position:absolute;bottom:0;right:0;width:80px;height:80px;background:radial-gradient(circle at bottom right,rgba(201,168,76,0.07),transparent);transition:all 0.4s}
.proj-card:hover{border-color:rgba(201,168,76,0.35);transform:translateY(-3px)}
.proj-card:hover::before{width:160px;height:160px}
.proj-year{font-family:var(--mono);font-size:0.65rem;color:var(--gold);letter-spacing:0.14em;margin-bottom:0.8rem}
.proj-name{font-family:var(--serif);font-size:1.3rem;font-weight:400;color:var(--white);margin-bottom:0.4rem;line-height:1.25}
.proj-org{font-size:0.75rem;color:var(--gold);margin-bottom:0.9rem}
.proj-desc{font-size:0.82rem;color:var(--muted);line-height:1.7;margin-bottom:1.2rem}

/* Certifications */
#certifications{background:var(--bg)}
.certs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0.9rem}
.cert-item{display:flex;align-items:flex-start;gap:1rem;padding:1.2rem 1.4rem;background:var(--bg3);border:1px solid var(--line);border-left:3px solid var(--line);transition:border-left-color 0.3s}
.cert-item:hover{border-left-color:var(--gold)}
.cert-icon{width:34px;height:34px;background:rgba(201,168,76,0.07);border:1px solid rgba(201,168,76,0.18);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:0.8rem}
.cert-name{font-size:0.85rem;font-weight:400;color:var(--text);margin-bottom:0.18rem;line-height:1.35}
.cert-issuer{font-size:0.72rem;color:var(--dim)}
.cert-year{font-family:var(--mono);font-size:0.65rem;color:var(--gold);margin-top:0.25rem}

/* Blog */
#blog{background:var(--bg2)}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
.blog-card{background:var(--bg3);border:1px solid var(--line);overflow:hidden;transition:all 0.3s;display:flex;flex-direction:column}
.blog-card:hover{border-color:rgba(201,168,76,0.35);transform:translateY(-3px)}
.blog-card-top{padding:2rem 2rem 1.5rem;flex:1}
.blog-cat{font-family:var(--mono);font-size:0.62rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--gold);margin-bottom:0.8rem}
.blog-title{font-family:var(--serif);font-size:1.2rem;font-weight:400;color:var(--white);margin-bottom:0.7rem;line-height:1.3}
.blog-excerpt{font-size:0.8rem;color:var(--muted);line-height:1.7}
.blog-card-footer{padding:1rem 2rem;border-top:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}
.blog-date{font-family:var(--mono);font-size:0.65rem;color:var(--dim)}
.blog-link{font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);text-decoration:none;transition:opacity 0.2s}
.blog-link:hover{opacity:0.7}
.blog-type{font-size:0.65rem;color:var(--dim);padding:0.2rem 0.55rem;border:1px solid var(--line)}

/* Footer */
footer{border-top:1px solid var(--line);padding:1.8rem 4rem;display:flex;justify-content:space-between;align-items:center}
.footer-copy{font-size:0.72rem;color:var(--dim);font-family:var(--mono)}
.footer-name{font-family:var(--serif);font-size:1rem;color:var(--gold)}

/* Reveal */
.reveal{opacity:0;transform:translateY(18px);transition:opacity 0.65s ease,transform 0.65s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.d1{transition-delay:0.1s}.d2{transition-delay:0.2s}.d3{transition-delay:0.3s}

@media(max-width:960px){
  nav{padding:1.1rem 1.5rem}
  .nav-links{display:none}
  section{padding:4rem 1.5rem}
  #hero{padding:5rem 1.5rem 3rem}
  .hero-inner{grid-template-columns:1fr;gap:3rem}
  .hero-photo-wrap{display:none}
  .about-grid{grid-template-columns:1fr;gap:2.5rem}
  .skills-grid,.projects-grid,.blog-grid,.awards-grid{grid-template-columns:1fr 1fr}
  .certs-grid{grid-template-columns:1fr}
  .exp-item{grid-template-columns:1fr;gap:0.4rem}
  footer{flex-direction:column;gap:0.5rem;text-align:center;padding:1.5rem}
}
@media(max-width:600px){
  .skills-grid,.projects-grid,.blog-grid,.awards-grid{grid-template-columns:1fr}
  .hero-name{font-size:2.5rem}
  .about-details{grid-template-columns:1fr}
  .certs-grid{grid-template-columns:1fr}
}
</style>
</head>
