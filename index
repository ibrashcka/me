    <div class="hero-photo-wrap">
      <div class="hero-photo-frame">
        <div class="photo-corner tl"></div><div class="photo-corner tr"></div>
        <div class="photo-corner bl"></div><div class="photo-corner br"></div>
        <img src="data:image/png;base64,
